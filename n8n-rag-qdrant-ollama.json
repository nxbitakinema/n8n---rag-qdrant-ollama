    {
      "parameters": {
        "jsCode": "// Loop over input items and extract image names from md_content\nfor (const item of $input.all()) {\n  const mdContent = item.json.document?.md_content || '';\n  const imageNames = [];\n  \n  // Regex to match markdown image syntax: ![alt](image_name.png)\n  // This captures the filename part in parentheses\n  const imageRegex = /!\\[.*?\\]\\((.*?)\\)/g;\n  \n  let match;\n  while ((match = imageRegex.exec(mdContent)) !== null) {\n    // match[1] contains the image filename\n    imageNames.push(match[1]);\n  }\n  \n  // Add the array of image names to the item\n  item.json.imageNames = imageNames;\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
