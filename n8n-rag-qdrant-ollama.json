    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor (const item of $input.all()) {\n\n  // Base URL for images\nconst baseUrl = \"http://localhost:8080/\";\n\n// Loop over input items and inject full URLs into md_content\nfor (const item of $input.all()) {\n  if (item.json.document && item.json.document.md_content) {\n    // Replace relative image paths with full URLS\n    // Pattern matches: ![AltText](image_filename.png)\n    item.json.document.md_content =\n      item.json.document.md_content.replace(\n        /!\\[([^\\]]*)\\]\\(([^\\)]+)\\)/g,\n        (match, altText, imagePath) => {\n          // Only add base URL if it's not already a full URL\n          if (!imagePath.startsWith('http://') &&\n              !imagePath.startsWith('https://')) {\n            return `![${altText}](${baseUrl}${imagePath})`;\n          }\n          return match;\n        }\n      );\n  }\n}\nreturn $input.all();\n  \n}\n\nreturn $input.all();"
      },
